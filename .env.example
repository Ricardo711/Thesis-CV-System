APP_NAME="Backend API"
ENV="local"
LOG_LEVEL="INFO"

MONGODB_URI="mongodb+srv://<username>:<password>@<cluster-url>/<database>"
MONGODB_DB="prediction_db"

CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,http://localhost:8501"

MEDIA_DIR="./media"
MEDIA_URL_PREFIX="/media"

# Local backend URL, e.g. http://localhost:8000
PUBLIC_BASE_URL="http://localhost:8000"

JWT_SECRET="your_jwt_secret_here"
JWT_ALG="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=120

AUTH_COOKIE_NAME="access_token"
AUTH_COOKIE_SAMESITE="lax"
AUTH_COOKIE_SECURE="false"

# Optional alternative Cloudinary config
# CLOUDINARY_URL="cloudinary://<api_key>:<api_secret>@<cloud_name>"

CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"